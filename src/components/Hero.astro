---
interface SocialLink {
  platform: string;
  url: string;
}

interface Props {
  title: string;
  tagline?: string;
  image: string;
  video?: string;
  videoSpeed?: number;
  videoOverlay?: number;
  size?: "full" | "compact";
  socialLinks?: SocialLink[];
}

const {
  title,
  tagline,
  image,
  video,
  videoSpeed = 1,
  videoOverlay = 4.5,
  size = "full",
  socialLinks = [],
} = Astro.props;

// theme.css exposes classes like "ph-video-cover-4-5" (opacity .45) for the overlay strength
const videoOverlayClass = `ph-video-cover-${String(videoOverlay).replace(".", "-")}`;

const iconByPlatform: Record<string, string> = {
  facebook: "fa-facebook-f",
  youtube: "fa-youtube",
  dribbble: "fa-dribbble",
  behance: "fa-behance",
};

const sizeClass = size === "full" ? "ph-full ph-full-m ph-cap-xxlg" : "ph-cap-lg";
---

<!-- ========================
	///// Begin page header /////
	============================= -->
<div id="page-header" class={`${sizeClass} ph-image-parallax ph-caption-parallax`}>
  {video ? (
    <div class={`ph-video ${videoOverlayClass}`}>
      <div class="ph-video-inner">
        <video loop muted autoplay playsinline preload="metadata" poster={image}>
          <source src="/assets/vids/placeholder.mp4" data-src={video} type="video/mp4" />
        </video>
      </div>
    </div>
  ) : null}
  {video && <div class="ph-video-grain" />}
  {video && videoSpeed !== 1 && (
    <script is:inline define:vars={{ videoSpeed }}>
      document.querySelectorAll("#page-header .ph-video video").forEach((v) => {
        v.playbackRate = videoSpeed;
        v.addEventListener("loadeddata", () => {
          v.playbackRate = videoSpeed;
        });
      });
    </script>
  )}
  {!video && (
    <div class="ph-image ph-image-cover-2">
      <div class="ph-image-inner">
        <img src={image} alt="Image" />
      </div>
    </div>
  )}

  <div class="page-header-inner tt-wrap">
    <div class="ph-caption">
      <div class="ph-caption-inner">
        <h1 class="ph-caption-title">{title}</h1>
        {tagline && <div class="ph-caption-description max-width-700">{tagline}</div>}
      </div>
      <!-- /.ph-caption-inner -->
    </div>
    <!-- /.ph-caption -->
  </div>
  <!-- /.page-header-inner -->

  {socialLinks.length > 0 && (
    <div class="ph-social">
      <ul>
        {socialLinks.map((link) => (
          <li>
            <a href={link.url} class="tt-magnetic-item" target="_blank" rel="noopener">
              <i class={`fa-brands ${iconByPlatform[link.platform] ?? "fa-link"}`}></i>
            </a>
          </li>
        ))}
      </ul>
    </div>
  )}

  {size === "full" && (
    <div class="tt-scroll-down">
      <a href="#tt-page-content" class="tt-scroll-down-inner tt-magnetic-item" data-offset="0">
        <div class="tt-scrd-icon"></div>
        <svg viewBox="0 0 500 500">
          <defs>
            <path
              d="M50,250c0-110.5,89.5-200,200-200s200,89.5,200,200s-89.5,200-200,200S50,360.5,50,250"
              id="textcircle"
            ></path>
          </defs>
          <text dy="30">
            <textPath xlink:href="#textcircle">Scroll to Explore - Scroll to Explore -</textPath>
          </text>
        </svg>
      </a>
      <!-- /.tt-scroll-down-inner -->
    </div>
  )}
</div>
<!-- End page header -->

<style>
  /*
    Film grain layer for the video hero, sitting as a sibling right after
    ".ph-video" so it paints on top of the video + darkening overlay
    (both z-index: -1, later in DOM wins) while staying below the normal-flow
    caption text. Reuses the same texture/animation as the theme's own
    ".tt-bg-noise" effect (theme.css) - see ".tt-noise" in CLAUDE.md.
  */
  .ph-video-grain {
    position: absolute;
    inset: 0;
    z-index: -1;
    overflow: hidden;
    pointer-events: none;
  }
  .ph-video-grain::before {
    content: "";
    position: absolute;
    top: -10rem;
    left: -10rem;
    width: calc(100% + 20rem);
    height: calc(100% + 20rem);
    background-image: url(/assets/img/bg-noise.png);
    background-position: 50%;
    animation: BgNoise 1s steps(2) infinite;
  }
</style>
